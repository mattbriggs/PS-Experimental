# Application
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info
APP_REGISTRY_PATH=config/registry.yaml
APP_FILENAME_MAX_LENGTH=200
APP_CORRELATION_ID_MAX_LENGTH=128

# WebDAV upstream
APP_WEBDAV_BASE_URL=http://localhost:8180
APP_WEBDAV_USERNAME=devuser
APP_WEBDAV_PASSWORD=changeme
APP_WEBDAV_CONNECT_TIMEOUT_SECONDS=5.0
APP_WEBDAV_READ_TIMEOUT_SECONDS=30.0
APP_WEBDAV_MAX_RETRIES=3
APP_WEBDAV_MAX_CONCURRENCY=20

# Authentication
APP_AUTH_API_KEY_ENABLED=true
APP_AUTH_OAUTH_ENABLED=false

# Operations
APP_READINESS_REQUIRES_WEBDAV=true
APP_AUDIT_REQUIRED=false
APP_METRICS_ENABLED=true
APP_RETRY_AFTER_SECONDS=30

# API keys injected as environment variables
# Format: API_KEY_<key-id>=scope1:read,scope2:read
# API_KEY_my-client-key=schematron:read,taxonomy:read
